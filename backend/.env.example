# Database
DATABASE_URL=postgresql+asyncpg://sisyphus:YOUR_DB_PASSWORD@localhost:5432/sisyphus

# API
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True

# JWT
JWT_SECRET=CHANGE_THIS_TO_RANDOM_STRING_IN_PRODUCTION
JWT_ALGORITHM=HS256
JWT_EXPIRATION=30

# LLM (用户配置)
# 默认使用环境变量，用户可在界面中配置
DEFAULT_LLM_PROVIDER=glm
DEFAULT_LLM_API_KEY=YOUR_API_KEY_HERE
